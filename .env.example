# Supabase — Shaandar CRM
# Copy this file to .env.local and fill in your project values.

# Required — from Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Required for server-side INSERT/FETCH and document uploads (keep secret!)
# Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Required for attendance bulk save (auto-creates employee_attendance + biometric_attendance)
# Supabase Dashboard → Project Settings → Database → Database password
SUPABASE_DB_PASSWORD=your-database-password-here

# Optional alternative — full Postgres connection string (overrides derived URL above)
# DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
