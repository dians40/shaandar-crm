// Shaandar CRM — public.biometric_attendance canonical schema
// Generate client: npx prisma generate
// Apply SQL: supabase/migrations/011_ensure_attendance_tables.sql

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Maps to public.biometric_attendance — canonical 23-column Excel import (22 data fields + date).
/// All ingest columns are optional strings except srl_no (stored as integer when numeric).
model BiometricAttendance {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  srlNo        Int?      @map("srl_no")
  payCode      String?   @map("pay_code")
  cardNo       String?   @map("card_no")
  employeeName String?   @map("employee_name")
  department   String?
  designation  String?
  shift        String?
  date         String?
  status       String?
  inTime       String?   @map("in_time")
  outTime      String?   @map("out_time")
  duration     String?
  earlyIn      String?   @map("early_in")
  lateIn       String?   @map("late_in")
  earlyOut     String?   @map("early_out")
  lateOut      String?   @map("late_out")
  otHours      String?   @map("ot_hours")
  shortHours   String?   @map("short_hours")
  grossHours   String?   @map("gross_hours")
  netHours     String?   @map("net_hours")
  workCode     String?   @map("work_code")
  remark       String?
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([payCode], map: "idx_biometric_attendance_pay_code")
  @@index([date], map: "idx_biometric_attendance_date_text")
  @@unique([payCode, date], map: "biometric_attendance_pay_code_date_key")
  @@map("biometric_attendance")
}

/// Maps to public.employee_attendance — legacy manual / workflow attendance log.
model EmployeeAttendance {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId     String   @map("employee_id") @db.Uuid
  attendanceDate DateTime @map("attendance_date") @db.Date
  status         String   @default("present")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([employeeId, attendanceDate], map: "employee_attendance_employee_id_attendance_date_key")
  @@index([employeeId], map: "idx_employee_attendance_employee_id")
  @@index([attendanceDate], map: "idx_employee_attendance_date")
  @@map("employee_attendance")
}

/// Draft/review staging — Step 1–4 biometric workflow.
model AttendanceStaging {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId       String?   @map("employee_id") @db.Uuid
  payCode          String    @map("pay_code")
  employeeName     String?   @map("employee_name")
  date             DateTime  @db.Date
  shiftDate        DateTime  @map("shift_date") @db.Date
  machineInTime    DateTime? @map("machine_in_time") @db.Timestamptz(6)
  machineOutTime   DateTime? @map("machine_out_time") @db.Timestamptz(6)
  correctedInTime  DateTime? @map("corrected_in_time") @db.Timestamptz(6)
  correctedOutTime DateTime? @map("corrected_out_time") @db.Timestamptz(6)
  duration         String?
  otHours          String?   @map("ot_hours")
  status           String    @default("Pending")
  isAnomaly        Boolean   @default(false) @map("is_anomaly")
  anomalyReason    String?   @map("anomaly_reason")
  editRemark       String?   @map("edit_remark")
  isLocked         Boolean   @default(false) @map("is_locked")
  approvedBy       String?   @map("approved_by")
  approvedAt       DateTime? @map("approved_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([payCode, shiftDate])
  @@map("attendance_staging")
}

model AttendanceAuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stagingId  String   @map("staging_id") @db.Uuid
  changedBy  String   @map("changed_by")
  changeType String   @map("change_type")
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  remark     String?
  timestamp  DateTime @default(now()) @db.Timestamptz(6)

  @@index([stagingId], map: "idx_attendance_audit_log_staging_id")
  @@map("attendance_audit_log")
}
