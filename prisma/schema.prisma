// Shaandar CRM — public.biometric_attendance canonical schema
// Generate client: npx prisma generate
// Apply SQL: supabase/migrations/010_biometric_attendance_canonical_schema.sql

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Maps to public.biometric_attendance — all fields optional for safe bulk ingestion.
model BiometricAttendance {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  srlNo        Int?      @map("srl_no")
  payCode      String?   @map("pay_code")
  cardNo       String?   @map("card_no")
  employeeName String?   @map("employee_name")
  department   String?
  designation  String?
  shift        String?
  date         String?
  status       String?
  inTime       String?   @map("in_time")
  outTime      String?   @map("out_time")
  duration     String?
  earlyIn      String?   @map("early_in")
  lateIn       String?   @map("late_in")
  earlyOut     String?   @map("early_out")
  lateOut      String?   @map("late_out")
  otHours      String?   @map("ot_hours")
  shortHours   String?   @map("short_hours")
  grossHours   String?   @map("gross_hours")
  netHours     String?   @map("net_hours")
  workCode     String?   @map("work_code")
  remark       String?
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([payCode], map: "idx_biometric_attendance_pay_code")
  @@index([date], map: "idx_biometric_attendance_date_text")
  @@unique([payCode, date], map: "biometric_attendance_pay_code_date_key")
  @@map("biometric_attendance")
}

/// Maps to public.employee_attendance — legacy manual / workflow attendance log.
model EmployeeAttendance {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId     String   @map("employee_id") @db.Uuid
  attendanceDate DateTime @map("attendance_date") @db.Date
  status         String   @default("present")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([employeeId, attendanceDate], map: "employee_attendance_employee_id_attendance_date_key")
  @@index([employeeId], map: "idx_employee_attendance_employee_id")
  @@index([attendanceDate], map: "idx_employee_attendance_date")
  @@map("employee_attendance")
}
